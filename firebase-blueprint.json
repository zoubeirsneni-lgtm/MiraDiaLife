{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with diabetes details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "diabetesType": { "type": "string", "enum": ["type1", "type2", "gestational"] },
        "age": { "type": "integer" },
        "since": { "type": "string", "format": "date" },
        "targetMin": { "type": "number" },
        "targetMax": { "type": "number" }
      },
      "required": ["name", "diabetesType"]
    },
    "Log": {
      "title": "Medical Log",
      "description": "Daily log for tracking diabetes stats",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["glucose", "activity", "food", "weight", "medication"] },
        "value": { "type": "number" },
        "medicationName": { "type": "string" },
        "mealType": { "type": "string", "enum": ["breakfast", "lunch", "dinner", "snack"] },
        "mealTime": { "type": "string", "enum": ["before", "after"] },
        "unit": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["userId", "timestamp", "type", "value"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/logs/{logId}": {
      "schema": "Log",
      "description": "Health tracking logs"
    }
  }
}
