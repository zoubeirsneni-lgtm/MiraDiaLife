rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'zoubeirsneni@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      function isValidProfile(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.diabetesType in ['type1', 'type2', 'gestational']
          && (!('age' in data) || data.age is number)
          && (!('since' in data) || data.since is string)
          && (!('targetMin' in data) || data.targetMin is number)
          && (!('targetMax' in data) || data.targetMax is number)
          && (!('insulinToCarbRatio' in data) || data.insulinToCarbRatio is number)
          && (!('insulinSensitivityFactor' in data) || data.insulinSensitivityFactor is number);
      }

      allow create: if isOwner(userId) && isValidProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidProfile(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'diabetesType', 'age', 'since', 'targetMin', 'targetMax', 'insulinToCarbRatio', 'insulinSensitivityFactor']);
    }

    // Health Logs
    match /users/{userId}/logs/{logId} {
      allow list: if isOwner(userId) || isAdmin();
      allow get: if isOwner(userId) || isAdmin();

      function isValidLog(data) {
        return data.userId == userId
          && data.timestamp == request.time
          && data.type in ['glucose', 'activity', 'food', 'weight', 'medication']
          && data.value is number
          && (!('medicationName' in data) || data.medicationName is string)
          && (!('mealType' in data) || data.mealType in ['breakfast', 'lunch', 'dinner', 'snack'])
          && (!('mealTime' in data) || data.mealTime in ['before', 'after'])
          && (!('unit' in data) || data.unit is string)
          && (!('notes' in data) || data.notes is string);
      }

      allow create: if isOwner(userId) && isValidLog(request.resource.data) && isValidId(logId);
      allow update: if isOwner(userId) && isValidLog(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['value', 'medicationName', 'mealType', 'mealTime', 'unit', 'notes', 'timestamp']);
      allow delete: if isOwner(userId);
    }
  }
}
